diff a/back/.env.example b/back/.env.example	(rejected hunks)
@@ -3,4 +3,18 @@ DATABASE_URL=sqlite:///./epp_dev.db
 SECRET_KEY=your-secret-key-here
 ALGORITHM=HS256
 ACCESS_TOKEN_EXPIRE_MINUTES=30
-REFRESH_TOKEN_EXPIRE_DAYS=7
\ No newline at end of file
+REFRESH_TOKEN_EXPIRE_DAYS=7
+
+# ─── Recuperación de contraseña ─────────────────────────────────────────────
+FRONTEND_URL=http://localhost:5173
+RESET_TOKEN_EXPIRE_MINUTES=30
+
+# ─── SMTP (envío de correos) ────────────────────────────────────────────────
+# Si usas Gmail: activa la verificación en 2 pasos y genera una "Contraseña
+# de aplicación" en https://myaccount.google.com/apppasswords — no uses tu
+# contraseña normal de Gmail aquí.
+SMTP_HOST=smtp.gmail.com
+SMTP_PORT=587
+SMTP_USER=tu_correo@gmail.com
+SMTP_PASSWORD=tu_contraseña_de_aplicacion
+SMTP_FROM=tu_correo@gmail.com
