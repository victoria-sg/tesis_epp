+    """Genera y envía un token de recuperación si el correo existe.
+
+    No revela si el correo está registrado o no: el router siempre
+    responde el mismo mensaje genérico, exista o no la cuenta.
+    """
+    user = get_by_correo(db, correo)
+    if not user:
+        return
+
+    # Invalida tokens anteriores no usados: solo el último pedido es válido.
+    recuperacion_repo.invalidar_anteriores(db, user.id_usuario)
