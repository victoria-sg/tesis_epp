+    except EnvioCorreoError as exc:
+        # No se relanza como error HTTP: si lo hiciéramos, un atacante
+        # podría distinguir "correo existe pero SMTP falló" (500) de
+        # "correo no existe" (200) y así enumerar correos registrados.
+        # El problema de configuración queda en el log del servidor.
+        logger.warning("No se pudo enviar el correo de recuperación: %s", exc)
